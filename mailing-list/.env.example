# ── Identity ─────────────────────────────────────────────────────────
DOMAIN=htl.ing
LIST_ADDRESS=ing@htl.ing
# Dedicated address for e-mail signup — any message sent here subscribes
# the sender (double opt-in), regardless of subject.
SIGNUP_ADDRESS=anmeldung@htl.ing
# Dedicated address for e-mail signout — any message sent here
# unsubscribes the sender, regardless of subject.
SIGNOUT_ADDRESS=abmeldung@htl.ing
LIST_NAME=htl.ing Mailingliste
FROM_ADDRESS=ing@htl.ing

# Public URL under which the web API is reachable (used in confirmation
# and unsubscribe links). Point a subdomain (e.g. list.htl.ing) at this
# server and put it behind a TLS-terminating reverse proxy (see README).
PUBLIC_BASE_URL=https://list.htl.ing

# ── Inbound SMTP (this server receives mail for LIST_ADDRESS) ─────────
SMTP_HOST=0.0.0.0
SMTP_PORT=25
# Optional STARTTLS certificate for the inbound SMTP listener
SMTP_TLS_KEY_PATH=
SMTP_TLS_CERT_PATH=

# ── Web API (signup form, confirm/unsubscribe links) ───────────────────
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
# Origin(s) allowed to call the API via fetch() from the browser,
# comma-separated. Must include the site that hosts the signup form.
CORS_ORIGINS=https://htl.ing,https://www.htl.ing

# ── Outbound mail (used to send confirmations & relay list posts) ─────
# Point this at a real relay/smarthost (e.g. a local Postfix instance,
# or a transactional provider). Do NOT rely on this server's own
# inbound listener for outbound delivery.
OUTBOUND_SMTP_HOST=127.0.0.1
OUTBOUND_SMTP_PORT=587
OUTBOUND_SMTP_SECURE=false
OUTBOUND_SMTP_USER=
OUTBOUND_SMTP_PASS=

# ── Optional DKIM signing of outbound mail (strongly recommended) ─────
DKIM_DOMAIN=htl.ing
DKIM_SELECTOR=list
DKIM_PRIVATE_KEY_PATH=

# ── Storage ─────────────────────────────────────────────────────────
DATA_DIR=./data

# ── Admin contact, used in footers / bounce notices ────────────────────
ADMIN_EMAIL=postmaster@htl.ing
